<% layout("layouts/boilerplate") %>

<main class="container">
    <div class="dcr row col-sm-6 col-md-6 col-lg-5 offset-3">
        <form method="post" action="/signup" class="row g-3 needs-validation" novalidate>
            <div>
                <label for="username" class="form-label"> UserName</label>
                    <input type="text" placeholder="Enter Your UserName" id="username" class="form-control" name="username" required>
                        <div class="valid-feedback">
                            <b> Looks good! </b>
                        </div>
                            <div class="invalid-feedback">
                                <b> Please Enter Your username! </b>
                            </div>
            </div>
                <div>
                    <label for="email" class="form-label"> E-Mail</label>
                        <input type="text" placeholder="Enter Your E-Mail" id="email" class="form-control" name="email" required>
                            <div class="valid-feedback">
                                <b> Looks good! </b>
                            </div>
                                <div class="invalid-feedback">
                                    <b> Please Enter Your E-Mail! </b>
                                </div>
                </div>
                    <div>     
                        <label for="password" class="form-label">Password</label>
                        <div class="eye">
                        <input type="password" placeholder="Enter Your Password" id="password" class="form-control" name="password" required>
                        <i class="fa-solid fa-eye eye_btn"></i>
                        </div>
                        <div class="valid-feedback">
                            <b> Looks good! </b>
                        </div>
                        <div class="invalid-feedback">
                            <b> Please Enter Your Password! </b>
                        </div>
                    </div>
                <button class="btn btn-outline-dark col-3 offset-4">      Submit     </button> 
        </form><br>
    </div>
</main>

<script>
    let eye_btn = document.querySelector(".eye_btn");
    let password = document.querySelector("#password");
    eye_btn.addEventListener("click",function(){
        if(password.type==="password"){
            password.type="text"
        }else{
            password.type="password"
        }
    });
</script>