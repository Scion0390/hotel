<% layout("layouts/boilerplate") %>

<% if(log && log.length>0){%>
<div class="alert alert-danger d-flex align-items-center alert-dismissible fade show" role="alert">
  <svg xmlns="http://www.w3.org/2000/svg " width="24" height="24" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2" viewBox="0 0 16 16" role="img" aria-label="Warning:">
    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
  </svg>
  <div>
    Please Login First!
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<%}%>
<% if(error && error.length>0){%>
<div class="alert alert-danger d-flex align-items-center alert-dismissible fade show" role="alert">
  <svg xmlns="http://www.w3.org/2000/svg " width="24" height="24" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2" viewBox="0 0 16 16" role="img" aria-label="Warning:">
    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
  </svg>
  <div>
    Invalid Username or Password!
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<%}%>


<main class="container">
    <div class="dcr row col-sm-6 col-md-6 col-lg-5 offset-3">
        <form method="post" action="/login" class="row g-3 needs-validation" novalidate>
            <div>
                <label for="username" class="form-label"> UserName OR E-mail</label>
                    <input type="text" placeholder="Enter Your UserName or E-mail" id="username" class="form-control" name="username" required>
                        <div class="valid-feedback">
                            <b> Looks good! </b>
                        </div>
                            <div class="invalid-feedback">
                                <b> Please Enter Your username! </b>
                            </div>
            </div>
                <div>     
                    <label for="password" class="form-label">Password</label>
                    <div class="eye">
                    <input type="password" placeholder="Enter Your Password" id="password" class="form-control" name="password" required>
                    <i class="fa-solid fa-eye eye_btn"></i>
                    </div>
                    <div class="valid-feedback">
                        <b> Looks good! </b>
                    </div>
                    <div class="invalid-feedback">
                        <b> Please Enter Your Password! </b>
                    </div>
                </div>
                    <button class="btn btn-outline-dark col-3 offset-4">      Submit     </button> 
        </form><br>
    </div>
</main>

<script>
    let eye_btn = document.querySelector(".eye_btn");
    let password = document.querySelector("#password");
    eye_btn.addEventListener("click",function(){
        if(password.type==="password"){
            password.type="text"
        }else{
            password.type="password"
        }
    });
</script>